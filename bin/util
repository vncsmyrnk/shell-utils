#!/usr/bin/env bash

# Given an input, interprets each argument as a part of a path to a script
# located at $SHELL_UTILS_SCRIPTS or $SHELL_UTILS_USER_CONFIG

# https://google.github.io/styleguide/shellguide.html

export SHELL_UTILS_SCRIPTS=${SHELL_UTILS_SCRIPTS:-"$HOME/.local/share/shell-utils/scripts"}
export SHELL_UTILS_USER_CONFIG=${SHELL_UTILS_USER_CONFIG:-"$HOME/.config/shell-utils"}
export SHELL_UTILS_USER_SCRIPTS=${SHELL_UTILS_USER_SCRIPTS:-"$SHELL_UTILS_USER_CONFIG/scripts"}
export SHELL_UTILS_CACHE_FILE=${SHELL_UTILS_CACHE_FILE:-"$HOME/.cache/shell-utils/scripts"}

check_empty_arguments() {
  [ $# -eq 0 ] && {
    printf "util is a shell-agnostic utility tool designed to make your scripts accessible everywhere using the util command.
It can find and execute your custom scripts like a CLI.
\ne.g. \"\$ util folder script\" will look for a script at \$SHELL_UTILS_USER_SCRIPTS/folder/script.(*)
More at https://github.com/vncsmyrnk/shell-utils\n"
    exit 0
  }
}

help_for_file() {
  printf "%s" "$(sed -n '/^# \[help\]/,/^$/p' "$1" |
    grep -v '^# \[help\]' |
    sed 's/^# //' |
    sed 's/^#//')"
}

print_help_for_file() {
  help_text=$(help_for_file "$1")
  if [ -n "$help_text" ]; then
    echo "$help_text"
    return 0
  fi

  echo "No help available"
  return 1
}

list_commands_available_glob() {
  help_file_for_current_path="$1/help"
  if [ -f "$help_file_for_current_path" ]; then
    printf "%s" "$(cat "$help_file_for_current_path")"
    printf "\n"
  else
    printf "This command has subcommands, but no help section.\n"
  fi

  printf "\n\033[4mCommands available:\033[0m\n"

  find "$1" \
    -maxdepth 1 \
    -type f \
    -not -iname 'help' \
    -not -name "_*" \
    -follow |
    while read -r file; do
      command_name=$(basename "$file" | rev | cut -f2- -d "." | rev)
      summarized_help_text=$(help_for_file "$file" | head -n 1)
      printf "\033[1m%s\033[0m" "$command_name"
      if [ -n "$summarized_help_text" ]; then
        printf " - %s" "$summarized_help_text"
      fi
      printf "\n"
    done

  find "$1" \
    -mindepth 1 \
    -maxdepth 1 \
    -type d \
    -follow |
    while read -r dir; do
      command_name=$(basename "$dir")
      printf "\033[1m%s\033[0m\n" "$command_name"
    done
}

find_and_execute_script() {
  query=""
  for arg in "$@"; do
    q="$q\\/$arg"
    query="$query|:${q:2}(\/|\.sh|\.zsh)?$"
  done

  candidate_paths=$(
    grep -P "${query:1}" "$SHELL_UTILS_CACHE_FILE"
  )
  if [ -z "$candidate_paths" ]; then
    echo "Not found"
    return
  fi

  candidate_paths=$(sed 's/:/\//' <<<"$candidate_paths")
  candidates=$(wc -l <<<"$candidate_paths")
  closest_match=$(tail -n 1 <<<"$candidate_paths")

  if [[ -d "$closest_match" ]] && [[ "$#" != "$candidates" ]]; then
    return
  fi

  if [[ -d "$closest_match" ]]; then
    list_commands_available_glob "$closest_match"
    exit 0
  fi

  if [[ ! -x "$closest_match" ]]; then
    return
  fi

  if [[ "$*" == *'--help'* ]]; then
    print_help_for_file "$closest_match" || {
      exit 1
    }
    exit 0
  fi

  if [[ "$*" == *'--to-stdout'* ]]; then
    cat "$closest_match"
    exit 0
  fi

  printf -v arguments " \"%s\" " "${@:(($candidates + 1))}"
  bash -c "$closest_match $arguments"
  exit
}

main() {
  "$SHELL_UTILS_SCRIPTS/cache/generate.sh"

  check_empty_arguments "$@"
  find_and_execute_script "$@"

  printf "Util file not found. Check \033[1m%s\033[0m for commands available.\n" "$SHELL_UTILS_USER_SCRIPTS"
  printf "\033[2mTip: pass file without the extension and make it sure it is executable.\033[0m\n"
  exit 1
}

main "$@"
