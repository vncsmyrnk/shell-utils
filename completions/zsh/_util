                    ;;
                jobs)
                    _util_jobs "$@" && ret=0
                    ;;
                locale)
                    _util_locale "$@" && ret=0
                    ;;
                nix)
                    _util_nix "$@" && ret=0
                    ;;
                pass)
                    _util_pass "$@" && ret=0
                    ;;
                random)
                    _util_random "$@" && ret=0
                    ;;
                totp)
